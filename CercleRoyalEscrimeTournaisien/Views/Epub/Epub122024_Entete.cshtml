@model CercleRoyalEscrimeTournaisien.Models.ModelEpub122024

@{
    var urlConvert = Url.Content("~/Home/Photos/NewEpub28012024/convert.png");
    var urlOpen = Url.Content("~/Home/Photos/NewEpub28012024/open.png");
    int taille;
    bool isMobileDeviceDetected = Model.IsMobileDeviceDetected;
    if (isMobileDeviceDetected) { taille = 15; } else { taille = 30; }
    string styleIconToListelAll = isMobileDeviceDetected ? "top: -2px;display: inline-block;zoom: 0.5;margin-left: -3px;" : "top: 13px;display: inline-block;zoom: 0.8;left:2.5em;";
}

<div id="divMain" class="TreeMainCollapse">
    <div class="ClassIconMobile glyphicon glyphicon-plus" style="margin-bottom: 10px; margin-left:10px; box-shadow: 4px 4px 20px 7px lightgrey;" id="ulToExpandCollapse">
        <i id="iconToListenAll" style="@styleIconToListelAll" onclick="StartPlayAllSentenceNew();" class="ClassIconMobile ClassSound ClassStyleSound fa fa-volume-up" aria-hidden="true"></i>
        <div id="divNextToExpandCollapse" style="display: none; margin-left: 15px; margin-top: 10px;  ">
            <div style="margin-bottom:10px;">
                <span id="SpanConvertEpub" style="font-family: arial;" class="ClassTextNode">
                    <a href="#" class="">Convertir Epub en texte</a>
                </span>
            </div>

            <div style="margin-bottom:10px;">
                <span id="SpanSelectEpub" style="font-family: arial;" class="ClassTextNode">
                    <a href="#" class="">Charger roman format texte</a>
                </span>
            </div>

            <div style="margin-top: 10px; margin-bottom: 20px;">
                <span class="row" style="margin-left:1px;margin-bottom:8px;font-family: FontAwesome;">Langue du livre:</span>
                @for (int i = 0; i < Model.CheckBoxLanguageItemsForLanguageDefault.Count; i++)
                {
                    <img class="imgFlag" height="@taille" width="@taille" src="@Url.Content(Model.CheckBoxLanguageItemsForLanguageDefault[i].UrlFlag)" />

                    if (Model.CheckBoxLanguageItemsForLanguageDefault[i].IsSelected)
                    {
                        @Html.RadioButtonFor(model => model.LanguageForLanguageDefaultSelected, Model.CheckBoxLanguageItemsForLanguageDefault[i].Language, new { @class = "ClassCheckboxNearFlag", @checked = Model.CheckBoxLanguageItemsForLanguageDefault[i].IsSelected ? "Checked" : "", @onclick = "ChangeLangueToTranslateAndRead();" })
                    }
                    else
                    {
                        @Html.RadioButtonFor(model => model.LanguageForLanguageDefaultSelected, Model.CheckBoxLanguageItemsForLanguageDefault[i].Language, new { @class = "ClassCheckboxNearFlag", @onclick = "ChangeLangueToTranslateAndRead();" })
                    }

                    @Html.HiddenFor(m => m.CheckBoxLanguageItemsForLanguageDefault[i].Language);
                }
            </div>

            <div class="row" style="font-family: FontAwesome; margin-bottom: 12px; ">
                <span style="margin-left:13px;margin-right:8px;margin-bottom:0px;font-family: FontAwesome;">Langue traduite et parlée:</span>
            </div>

            <div style="font-family: FontAwesome; margin-bottom: 17px;">
                @for (int i = 0; i < Model.CheckBoxLanguageItemsForTraduceAutomatically.Count; i++)
                {
                    <img class="imgFlag" height="@taille" width="@taille" src="@Url.Content(Model.CheckBoxLanguageItemsForTraduceAutomatically[i].UrlFlag)" />
                    @Html.CheckBoxFor(model => model.CheckBoxLanguageItemsForTraduceAutomatically[i].IsSelected, new { @value= Model.CheckBoxLanguageItemsForTraduceAutomatically[i].Language, @class = "ClassSecondCheckboxNearFlag" })
                }
            </div>

            <div style="font-family: FontAwesome; margin-bottom: 17px;">
                <span>Arrêt automatique: </span>
                @Html.TextBoxFor(x => x.TimeArretAutomatique, new { @class = "", style = "width: 50px;" })
                <input style="height: 26px; width: 106px; background-color: orange; color: black; text-align: center; text-decoration: none; display: inline-block; font-size: 16px; border-radius: 3px; border: none; margin-left: 8px;" type="button" value="Appliquer" onclick="AddTimeToFinishTheRead();" />
            </div>
        </div>
    </div>
</div>

<div class="classInputFile">
    <input type="file" title=" " id="inputFile" name="inputFile" style="display:none;" />
</div>